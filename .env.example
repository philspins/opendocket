# Division Bell example environment configuration
# Copy to .env and fill in real values for your environment.

# --- Crawler / Summarizer ---
CRAWLER_PARALLELISM=5
SUMMARIZER_PARALLELISM=1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Auth / Server ---
OAUTH_BASE_URL=http://127.0.0.1:8080
SES_FROM_EMAIL=
# Set to "true" only when the server runs behind a trusted reverse proxy that
# strips/re-sets X-Forwarded-For and X-Real-IP (e.g. nginx, Caddy, ALB).
# Leaving this unset (or false) prevents clients from spoofing their IP.
# When TRUST_PROXY=true and OAUTH_BASE_URL starts with https://, the server
# will also redirect plain-HTTP requests (X-Forwarded-Proto: http) to HTTPS
# and will set the Strict-Transport-Security (HSTS) header on HTTPS responses.
# The /health endpoint is always exempt from the redirect so ALB health checks
# succeed regardless of which protocol the health check uses.
TRUST_PROXY=false

# Optional social login providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- AWS SES credentials (optional if using role/profile credentials) ---
AWS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# --- Address lookup / geocoding ---
GOOGLE_MAPS_API_KEY=

# --- Frontend theme override (optional) ---
PARTY_THEME_FILE=config/party-theme.json

package templates

import (
	"fmt"
	"github.com/philspins/opendocket/internal/store"
)

templ BillDetail(ps store.ParliamentStatus, bill store.BillRow, stages []store.BillStageRow, divs []store.DivisionRow, reactions store.BillReactionCounts, isAuthenticated bool, isSubscribed bool) {
	@Layout(bill.Number+" — "+ShortOrFullTitle(bill), ps) {
		<div class="space-y-6">
			<!-- Header -->
			<div>
				<div class="flex items-center gap-2 mb-2">
					<a href="/bills" class="text-sm text-blue-600 hover:underline">← Bills</a>
				</div>
				<div class="flex items-start justify-between gap-3">
					<div class="flex items-center gap-3 flex-wrap">
						<span class="font-mono font-bold text-2xl text-blue-700">{ bill.Number }</span>
						@BillLevelBadge(bill)
						if bill.Category != "" {
							@CategoryBadge(bill.Category, "text-xs px-2 py-0.5")
						}
					</div>
					@billSubscribeButton(bill.ID, isAuthenticated, isSubscribed)
				</div>
				<h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mt-2">{ bill.Title }</h1>
				if bill.ShortTitle != "" && bill.ShortTitle != bill.Title {
					<p class="text-gray-600 dark:text-gray-400 italic mt-1">{ bill.ShortTitle }</p>
				}
			</div>

			<!-- Meta grid + Progress bar on the same row -->
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 items-stretch">
				<div class="panel flex flex-row gap-4">
					<div class="flex-1 min-w-0">
						<p class="text-xs text-gray-500 dark:text-gray-400">Chamber</p>
						<p class="font-medium dark:text-gray-200">{ ChamberLabel(bill.Chamber) }</p>
					</div>
					<div class="flex-1 min-w-0">
						<p class="text-xs text-gray-500 dark:text-gray-400">Stage</p>
						<p class="font-medium dark:text-gray-200">{ StageLabel(bill.CurrentStage) }</p>
					</div>
					if bill.SponsorName != "" {
						<div class="flex-1 min-w-0">
							<p class="text-xs text-gray-500 dark:text-gray-400">Sponsor</p>
							<p class="font-medium dark:text-gray-200 truncate">
								if bill.SponsorID != "" {
									<a href={ templ.SafeURL("/members/" + bill.SponsorID) } class="text-blue-600 hover:underline">{ bill.SponsorName }</a>
								} else {
									{ bill.SponsorName }
								}
							</p>
						</div>
					}
					<div class="flex-1 min-w-0">
						<p class="text-xs text-gray-500 dark:text-gray-400">Introduced</p>
						<p class="font-medium dark:text-gray-200">{ FormatDate(bill.IntroducedDate) }</p>
					</div>
				</div>
				if bill.CurrentStage != "" {
					<div class="panel h-full">
						<p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3">Progress</p>
						@stageProgress(bill.CurrentStage)
					</div>
				}
			</div>

			<!-- Summaries + Constituent Sentiment in a 2-column layout -->
			{{ aiSummary := ParseAISummary(bill.SummaryAI) }}
			<!-- One-sentence summary banner (full width) -->
			if aiSummary.OneSentence != "" {
				<div class="callout-info">
					<p class="font-medium">{ aiSummary.OneSentence }</p>
				</div>
			}
			if bill.SummaryLoP != "" {
				<div class="callout-info">
					<p class="text-xs font-semibold uppercase tracking-wide mb-1" style="color:var(--ink-500)">Library of Parliament</p>
					<p class="text-sm">{ bill.SummaryLoP }</p>
				</div>
			}

			<!-- Content panels + Summary -->
			<!-- Desktop (≥900px): two independent flex-col stacks side-by-side — no shared row heights, no checkerboard stagger -->
			<!--   Left col:  Key Changes → Who's Affected                                                                       -->
			<!--   Right col: Vibes → Gotchas                                                                                    -->
			<!-- Mobile (<900px): Key Changes → Gotchas → Who's Affected → Summary → Vibes (via DOM order + hidden duplicates)   -->
			<div class="flex flex-col min-[900px]:flex-row gap-4 min-[900px]:items-start">
				<!-- Left column -->
				<div class="flex flex-col gap-4 min-[900px]:flex-1">
					if len(aiSummary.KeyChanges) > 0 {
						<div class="panel">
							<p class="text-xs font-semibold uppercase tracking-wide mb-2" style="color:var(--ink-500)">Key Changes</p>
							<ul class="list-disc list-inside space-y-1">
								for _, item := range aiSummary.KeyChanges {
									<li class="text-sm">{ item }</li>
								}
							</ul>
						</div>
					}
					<!-- Gotchas — mobile only (hidden on desktop; appears here so mobile order is KC → Gotchas → WA) -->
					if len(aiSummary.NotableConsiderations) > 0 {
						<div class="panel min-[900px]:hidden">
							<p class="text-xs font-semibold uppercase tracking-wide mb-2" style="color:var(--ink-500)">Gotchas</p>
							<ul class="list-disc list-inside space-y-1">
								for _, item := range aiSummary.NotableConsiderations {
									<li class="text-sm">{ item }</li>
								}
							</ul>
						</div>
					}
					if len(aiSummary.WhoIsAffected) > 0 {
						<div class="panel">
							<p class="text-xs font-semibold uppercase tracking-wide mb-2" style="color:var(--ink-500)">Who&#39;s Affected</p>
							<ul class="list-disc list-inside space-y-1">
								for _, item := range aiSummary.WhoIsAffected {
									<li class="text-sm">{ item }</li>
								}
							</ul>
						</div>
					}
				</div>
				<!-- Right column — desktop only (hidden on mobile; Vibes+Gotchas stack independently, no shared row heights) -->
				<div class="hidden min-[900px]:flex flex-col gap-4 flex-1">
					<div class="panel">
						<h2 class="text-sm font-semibold uppercase tracking-wide mb-3" style="color:var(--ink-700)">Vibes</h2>
						<div class="flex gap-4 items-center">
							<!-- Pie chart -->
							<div class="flex flex-col items-center gap-1 shrink-0">
								@templ.Raw(ReactionPieChartSVG(reactions.SupportCount, reactions.OpposeCount, reactions.NeutralCount, reactions.TotalReactions))
								<p class="text-xs" style="color:var(--ink-500)">{ fmt.Sprint(reactions.TotalReactions) } responses</p>
							</div>
							<!-- Legend -->
							<div class="flex-1 space-y-1 text-sm">
								<div class="flex items-center gap-2">
									<span class="inline-block w-2.5 h-2.5 bg-green-500 shrink-0"></span>
									<span style="color:var(--ink-700)">Support</span>
									<span class="ml-auto font-medium" style="color:var(--ink-900)">{ fmt.Sprint(reactions.SupportCount) }</span>
								</div>
								<div class="flex items-center gap-2">
									<span class="inline-block w-2.5 h-2.5 bg-gray-400 shrink-0"></span>
									<span style="color:var(--ink-700)">Neutral</span>
									<span class="ml-auto font-medium" style="color:var(--ink-900)">{ fmt.Sprint(reactions.NeutralCount) }</span>
								</div>
								<div class="flex items-center gap-2">
									<span class="inline-block w-2.5 h-2.5 bg-red-500 shrink-0"></span>
									<span style="color:var(--ink-700)">Oppose</span>
									<span class="ml-auto font-medium" style="color:var(--ink-900)">{ fmt.Sprint(reactions.OpposeCount) }</span>
								</div>
							</div>
							@billInteractionControls(bill.ID, isAuthenticated)
						</div>
					</div>
					if len(aiSummary.NotableConsiderations) > 0 {
						<div class="panel">
							<p class="text-xs font-semibold uppercase tracking-wide mb-2" style="color:var(--ink-500)">Gotchas</p>
							<ul class="list-disc list-inside space-y-1">
								for _, item := range aiSummary.NotableConsiderations {
									<li class="text-sm">{ item }</li>
								}
							</ul>
						</div>
					}
				</div>
			</div>

			<!-- Summary — full width on both mobile and desktop -->
			if aiSummary.PlainSummary != "" {
				<div class="panel">
					<p class="text-xs font-semibold uppercase tracking-wide mb-2" style="color:var(--ink-500)">Summary</p>
					<p class="text-sm">{ aiSummary.PlainSummary }</p>
					if bill.SummaryAI != "" || bill.SummaryLoP != "" {
						<p class="text-xs text-gray-400 dark:text-gray-500 mt-2">
							if bill.SummaryLoP != "" {
								Source: Library of Parliament
							} else {
								Automatically generated from bill text using Claude
							}
						</p>
					}
				</div>
			}

			<!-- Vibes — mobile only (hidden on desktop; appears after Summary so mobile order ends: … → Summary → Vibes) -->
			<div class="panel min-[900px]:hidden">
				<h2 class="text-sm font-semibold uppercase tracking-wide mb-3" style="color:var(--ink-700)">Vibes</h2>
				<div class="flex gap-4 items-center">
					<!-- Pie chart -->
					<div class="flex flex-col items-center gap-1 shrink-0">
						@templ.Raw(ReactionPieChartSVG(reactions.SupportCount, reactions.OpposeCount, reactions.NeutralCount, reactions.TotalReactions))
						<p class="text-xs" style="color:var(--ink-500)">{ fmt.Sprint(reactions.TotalReactions) } responses</p>
					</div>
					<!-- Legend -->
					<div class="flex-1 space-y-1 text-sm">
						<div class="flex items-center gap-2">
							<span class="inline-block w-2.5 h-2.5 bg-green-500 shrink-0"></span>
							<span style="color:var(--ink-700)">Support</span>
							<span class="ml-auto font-medium" style="color:var(--ink-900)">{ fmt.Sprint(reactions.SupportCount) }</span>
						</div>
						<div class="flex items-center gap-2">
							<span class="inline-block w-2.5 h-2.5 bg-gray-400 shrink-0"></span>
							<span style="color:var(--ink-700)">Neutral</span>
							<span class="ml-auto font-medium" style="color:var(--ink-900)">{ fmt.Sprint(reactions.NeutralCount) }</span>
						</div>
						<div class="flex items-center gap-2">
							<span class="inline-block w-2.5 h-2.5 bg-red-500 shrink-0"></span>
							<span style="color:var(--ink-700)">Oppose</span>
							<span class="ml-auto font-medium" style="color:var(--ink-900)">{ fmt.Sprint(reactions.OpposeCount) }</span>
						</div>
					</div>
					@billInteractionControls(bill.ID, isAuthenticated)
				</div>
			</div>

			<!-- External links -->
			<div class="flex gap-4">
				if bill.LegisInfoURL != "" {
					<a href={ templ.SafeURL(bill.LegisInfoURL) } target="_blank" rel="noopener"
					   class="text-sm text-blue-600 hover:underline">LEGISinfo →</a>
				}
				if bill.FullTextURL != "" {
					<a href={ templ.SafeURL(bill.FullTextURL) } target="_blank" rel="noopener"
					   class="text-sm text-blue-600 hover:underline">Full Text →</a>
				}
			</div>

			<!-- Divisions -->
			if len(divs) > 0 {
				<section>
					<h2 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-3">Recorded Votes</h2>
					<div class="overflow-x-auto">
						<table class="min-w-full text-sm">
							<thead>
								<tr class="bg-gray-50 dark:bg-gray-800/50 text-left text-xs text-gray-500 dark:text-gray-400">
									<th class="px-3 py-2">Date</th>
									<th class="px-3 py-2">Description</th>
									<th class="px-3 py-2 text-right">Yeas</th>
									<th class="px-3 py-2 text-right">Nays</th>
									<th class="px-3 py-2">Result</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-gray-100 dark:divide-gray-700">
								for _, d := range divs {
									<tr class="hover:bg-gray-50 dark:hover:bg-gray-800/30">
										<td class="px-3 py-2 text-gray-500 dark:text-gray-400 whitespace-nowrap">{ FormatDate(d.Date) }</td>
										<td class="px-3 py-2 dark:text-gray-300">{ d.Description }</td>
										<td class="px-3 py-2 text-right text-green-600 font-medium">{ fmt.Sprint(d.Yeas) }</td>
										<td class="px-3 py-2 text-right text-red-600 font-medium">{ fmt.Sprint(d.Nays) }</td>
										<td class="px-3 py-2 text-gray-600 dark:text-gray-400">{ d.Result }</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				</section>
			}
		</div>
	}
}

templ billInteractionControls(billID string, isAuthenticated bool) {
	if isAuthenticated {
		<div class="flex flex-col gap-1 shrink-0">
			<form method="POST" action="/api/react" class="inline">
				<input type="hidden" name="bill_id" value={ billID }/>
				<input type="hidden" name="reaction" value="support"/>
				<button type="submit" title="Support" class="text-base hover:scale-110 transition-transform" aria-label="Support this bill">👍</button>
			</form>
			<form method="POST" action="/api/react" class="inline">
				<input type="hidden" name="bill_id" value={ billID }/>
				<input type="hidden" name="reaction" value="neutral"/>
				<button type="submit" title="Neutral" class="text-base hover:scale-110 transition-transform" aria-label="Neutral on this bill">🤔</button>
			</form>
			<form method="POST" action="/api/react" class="inline">
				<input type="hidden" name="bill_id" value={ billID }/>
				<input type="hidden" name="reaction" value="oppose"/>
				<button type="submit" title="Oppose" class="text-base hover:scale-110 transition-transform" aria-label="Oppose this bill">👎</button>
			</form>
		</div>
	} else {
		<div class="flex flex-col gap-1 shrink-0 opacity-40">
			<div class="relative group flex justify-center">
				<button type="button" class="text-base cursor-not-allowed" aria-label="Login to share your opinion" aria-disabled="true">👍</button>
				<span class="pointer-events-none absolute left-full ml-2 top-1/2 -translate-y-1/2 whitespace-nowrap rounded bg-gray-900 px-2 py-1 text-sm text-white opacity-0 transition-opacity group-hover:opacity-100">
					login to share your opinion
				</span>
			</div>
			<div class="relative group flex justify-center">
				<button type="button" class="text-base cursor-not-allowed" aria-label="Login to share your opinion" aria-disabled="true">🤔</button>
				<span class="pointer-events-none absolute left-full ml-2 top-1/2 -translate-y-1/2 whitespace-nowrap rounded bg-gray-900 px-2 py-1 text-sm text-white opacity-0 transition-opacity group-hover:opacity-100">
					login to share your opinion
				</span>
			</div>
			<div class="relative group flex justify-center">
				<button type="button" class="text-base cursor-not-allowed" aria-label="Login to share your opinion" aria-disabled="true">👎</button>
				<span class="pointer-events-none absolute left-full ml-2 top-1/2 -translate-y-1/2 whitespace-nowrap rounded bg-gray-900 px-2 py-1 text-sm text-white opacity-0 transition-opacity group-hover:opacity-100">
					login to share your opinion
				</span>
			</div>
		</div>
	}
}

templ billSubscribeButton(billID string, isAuthenticated bool, isSubscribed bool) {
	if isAuthenticated {
		<form method="POST" action="/api/subscribe-bill" class="shrink-0">
			<input type="hidden" name="bill_id" value={ billID }/>
			if isSubscribed {
				<button type="submit" class="btn btn-secondary text-sm" title="Unsubscribe from this bill" aria-label="Unsubscribe from this bill">
					📌 Subscribed
				</button>
			} else {
				<button type="submit" class="btn btn-secondary text-sm" title="Subscribe to pin this bill to the top of your feed" aria-label="Subscribe to this bill">
					📌 Subscribe
				</button>
			}
		</form>
	} else {
		<div class="shrink-0 relative group">
			<button type="button" class="btn btn-secondary text-sm opacity-50 cursor-not-allowed" aria-disabled="true" aria-label="Login to subscribe to this bill">
				📌 Subscribe
			</button>
			<span class="pointer-events-none absolute right-0 top-full mt-1 whitespace-nowrap rounded bg-gray-900 px-2 py-1 text-xs text-white opacity-0 transition-opacity group-hover:opacity-100">
				Login to subscribe to this bill
			</span>
		</div>
	}
}
